# ══════════════════════════════════════════════
# GB-BRAIN — Environment Variables
# ══════════════════════════════════════════════
# Copy this file to .env and fill in your keys
# NEVER commit .env to GitHub
# ══════════════════════════════════════════════

# ── GitHub (for harvesting strategies) ───────
GITHUB_TOKEN=ghp_your_token_here

# ── Binance ──────────────────────────────────
BINANCE_API_KEY=your_binance_key
BINANCE_API_SECRET=your_binance_secret

# ── Alpaca ───────────────────────────────────
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── OANDA (demo account) ────────────────────
OANDA_ACCOUNT_ID=your_oanda_account_id
OANDA_API_TOKEN=your_oanda_token
OANDA_API_URL=https://api-fxpractice.oanda.com

# ── BloFin ───────────────────────────────────
BLOFIN_API_KEY=your_blofin_key
BLOFIN_API_SECRET=your_blofin_secret
BLOFIN_PASSPHRASE=your_blofin_passphrase

# ── Telegram Notifications ───────────────────
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ── TradingView Webhook ─────────────────────
TV_WEBHOOK_SECRET=your_webhook_secret
TV_WEBHOOK_PORT=5000
